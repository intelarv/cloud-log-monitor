{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:temporal": "bash ./scripts/run-temporal-integration.sh",
    "reindex:search": "pnpm run build && node --enable-source-maps ./dist/scripts/reindex-search.mjs",
    "eval": "rm -rf evals/results && vitest run --config vitest.eval.config.ts && node evals/gate.mjs",
    "eval:update": "rm -rf evals/results && vitest run --config vitest.eval.config.ts && node evals/gate.mjs --update"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@ag-ui/core": "^0.0.54",
    "@ag-ui/encoder": "^0.0.54",
    "@google/genai": "^1.52.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-gemini-ai": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jose": "^6.2.3",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "vitest": "^4.1.7"
  },
  "optionalDependencies": {
    "@octokit/rest": "^21.1.1",
    "@temporalio/client": "^1.18.0",
    "@temporalio/worker": "^1.18.0",
    "@temporalio/workflow": "^1.18.0"
  }
}
